<?xml version = "1.0" encoding = "UTF-8" ?>

<dictionary>

	<!--Lugar vacio antes de la entrada a la caverna-->
	<noun names = "escape-caverna" />

	<noun names = "Entrada a La Caverna, entrada">

		<!-- descripción -->
		<after actions = "LookAround">
			<response class = "Message">
				Por la caverna siempre abierta logra colarse la luz, pero no por mucha. Al dar algunos pasos hacia el norte la negrura te invade. Hacia el sur, huyes.
			</response>
		</after>

		<noun names = "jugador, player">
			<noun names = "linterna, lumbre, luz">
				<set>female, container</set>

				<after actions = "ExamineObject">
					<response class = "Message">
						La linterna a baterías piensa acompañarte por éste tenebroso lugar.
					</response>
				</after>
				
				<noun names = "baterias, pilas">
					<set>female, plural</set>
				</noun>
			</noun>
		</noun>

		<noun names = "bola roja, roja, bola">
			<set>female</set>
			<after actions = "ExamineObject">
				<response class = "Message">
					Una bola de color rojo
				</response>
			</after>
		</noun>

		<noun names = "bola verde, verde, bola">
			<set>female</set>
			<after actions = "ExamineObject">
				<response class = "Message">
					Una bola de color verder
				</response>
			</after>
		</noun>

		<!--Al intentar huir-->
		<before actions = "GoTo" cancel = "true">
			<if class = "DirectEqualsExit" exit = "sur" />
			<response class = "Message">
				No veo porque irse ahora.
			</response>
		</before>

		<connection exit = "sur" destiny = "escape-cavernas" />
	</noun>

</dictionary>