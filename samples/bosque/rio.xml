<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE dragonfly SYSTEM "../../templates/dragonfly.dtd">

<dragonfly>
	<noun names="A La Orilla del Río, orilla-rio">
		<after actions="LookAround">
			El sendero continua hacia la orilla de un río, luego dobla hacia el norte.
		</after>

		<clone instance="sendero-principal" />
		<clone instance="arboles-principal" />

		<noun names="río, orilla, agua, arroyo">
			<set>fixed, scene</set>
			<after actions="ExamineObject">
				Con un torrente bastante fuerte, el ancho río se complica para cruzar.
			</after>

			<noun names="hongo, seta">
				<after actions="ExamineObject">
					Es de color azul y despide un aroma extraño.
				</after>
			</noun>
		</noun>

		<connection exit="oeste" destiny="arbol-naranja" />
		<connection exit="norte" destiny="casa-afuera" />
	</noun>
</dragonfly>
