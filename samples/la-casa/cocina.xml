<?xml version="1.0" encoding="UTF-8"?>

<dragonfly>
	<noun names="La Cocina, cocina">
		<after actions="LookAround">
			<response class="Message">
				En la cocina hay mesadas y un horno microondas. Por el sur se vuelve al comedor a través de la puerta vainvén.
			</response>
		</after>

		<!-- Las mesadas -->
		<noun names="mesadas, mesas">
			<set>female, plural, fixed, scene</set>

			<after actions="ExamineObject">
				<response class="Message">
					No hay nada interesante en las mesadas
				</response>
			</after>
		</noun>

		<!-- El horno de microondas -->
		<noun names="horno microondas, horno, microondas">
			<set>heavy, scene, container, closable, closed, bloqueado</set>
			<!-- bloqueado: atributo personalizado que indicará el bloqueo del microondas -->

			<after actions="ExamineObject">
				<response class="Message">
					El horno de microondas está sobre una de las mesadas. Tine un display con un teclado numérico.
				</response>
			</after>

			<!-- ANTES de ABRIR el microondas -->
			<before actions="OpenObject, OpenWith" cancel="true">
				<!-- CANCELAR SI existe el atributo "bloqueado" -->
				<if class="IsSet" attr="bloqueado" instance="microondas" />
				<response class="Message">
					Está bloqueado. Extraño ...
				</response>
			</before>

			<!-- ANTES de ENCENDER o APAGAR el microondas -->
			<before actions="TurnOnObject, TurnOffObject" cancel="true">
				<response class="Message">
					No parece responder.
				</response>
			</before>
		</noun>

		<!-- La puerta vaivén -->
		<noun names="puerta vaivén, puerta, vaiven">
			<set>female, scene, definited</set>
			<after actions="ExamineObject">
				<response class="Message">
					La puerta vaiven separa el comedor de la cocina.
				</response>
			</after>

			<before actions="TakeObject" cancel="true">
				<response class="Message">No me puedo llevar la puerta vaivén.</response>
			</before>

			<before actions="OpenObject, OpenWith, CloseObject, CloseWith" cancel="true">
				<response class="Message">Es vaivén ...</response>
			</before>
		</noun>

		<connection exit="sur" destiny="comedor" />
	</noun>
</dragonfly>
