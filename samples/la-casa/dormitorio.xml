<?xml version="1.0" encoding="UTF-8"?>

<dragonfly>
	<noun names="Dormitorio">

		<!-- Descripción del dormitorio -->
		<after actions="LookAround">
			<response class="Message">
				Dentro del dormitorio puedes una cama y una mesita de luz con una lámpara. Por el sur vuelves al pasillo.
			</response>
		</after>

		<!-- La única puerta -->
		<noun names="puerta, puerta sur, sur, puerta-dormitorio-pasillo">

			<set>female, fixed, closable, closed, scene</set>
	
			<after actions="ExamineObject">
				<response class="Message">
					La puerta es de madera.
				</response>
			</after>
	
			<after actions="OpenObject">
				<response class="Attr" unset="closed" instance="puerta-pasillo-dormitorio" />
			</after>
	
			<after actions="CloseObject">
				<response class="Attr" set="closed" instance="puerta-pasillo-dormitorio" />
			</after>
	
		</noun>

		<!-- La cama -->
		<noun names="cama, camastro, catre, cubrecama, acolchado, sabanas, sabana, colchon">
			<set>female, heavy, scene</set>

			<after actions="ExamineObject">
				<response class="Message">
					Es de madera y tiene un colchon con sabanas y todo.
				</response>
			</after>
		</noun>

		<!-- Mesita de luz -->
		<noun names="mesita de luz, mesita, mesa">
			<set>female, heavy, scene</set>

			<after actions="ExamineObject">
				<response class="Message">
					La mesita de caoba posee un cajón y tiene una lámpara para las noches en vela.
				</response>
			</after>
		</noun>

		<!-- El cajón de la mesita de luz -->
		<noun names="cajón de la mesita, cajon, cajonera">
			<set>fixed, container, closable, closed, scene</set>
			<!-- container: el objeto reacciónará a verbos como "sacar de",
				"poner objeto en", "mirar en". Entonces el parser tendrá en cuenta
				los hijos del objeto para poder interactuar con el jugador. -->
			<!-- Si el objeto es closable "cerrable" el jugador tendrá que "abrir"
				el objeto para poder "mirar adentro" como en el caso del cajón -->

			<!-- La descripción cambia si está cerrado o abierto-->
			<after actions="ExamineObject">
				<if class="IsSet" attr="closed" instance="cajon" />
				<response class="Message">
					Es del mismo material de la mesita y está cerrado.
				</response>
			</after>
			<after actions="ExamineObject">
				<if class="IsNotSet" attr="closed" instance="cajon" />
				<response class="Message">
					Es del mismo material de la mesita y está abierto.
				</response>
			</after>
		</noun>

		<!-- Lámpara -->
		<noun names="lámpara, luz, luces, foco">
			<set>female, scene</set>

			<after actions="ExamineObject">
				<response class="Message">
					La lámpara es de color verde.
				</response>
			</after>

			<!-- El personaje desiste de llevarse la lampara -->
			<before actions="TakeObject" cancel="true">
				<response class="Message">
					¿Y qué voy a hacer con la lámpara?
				</response>
			</before>
		</noun>
	
		<connection exit="sur" destiny="pasillo" />
	
		<before actions="GoTo" cancel="true">
			<if class="DirectEqualsExit" exit="sur" />
			<if class="IsSet" attr="closed" instance="puerta-dormitorio-pasillo" />
			<response class="Message">
				Primero abre la puerta.
			</response>
		</before>
	</noun>

</dragonfly>
