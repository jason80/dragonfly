<?xml version="1.0" encoding="UTF-8"?>

<!-- Todo archivo Dragonfly es de formato XML. Debe declararse el encabezado y su
 		elemento raíz siempre se debe llamar "dragonfly" -->	

<dragonfly>
	<!-- Datos básicos del juego -->
	<game title="La Casa" author="Javier Candales" />

	<!-- Incluye el diccionario en español y los verbos de depuración -->
	<include path="../../templates/dict-es.xml" />
	<include path="../../templates/dict-debug.xml" />

	<!-- Establece algunas propiedades. -->
	<!-- Las propiedades son globales y se están disponibles en cualquier parte. -->
	<property name="show-parsing-process" value="false" /> <!-- Muestra el análisis sintáctico de una
		oración, paso a paso-->	
	<property name="hide-title" value="false"/> <!-- ¿Ocultar el título del juego? -->
	<property name="look-around" value="always" /> <!-- ¿Cuándo se muestra la descripción
		de los lugares?
		never: nunca.
		on-start: al principio del juego.
		always: cada vez que el jugador entra a un lugar -->
	<property name="player" value="jugador"/> <!-- ¿Quién es el jugador? -->

	<!-- Incluye los diferentes lugares del juego -->
	<include path="./living.xml"/> <!-- Aquí se encuentra el jugador -->
	<include path="./pasillo.xml"/>
	<include path="./dormitorio.xml" />
	<include path="./toilette.xml" />
	<include path="./comedor.xml" />
	<include path="./cocina.xml" /> 

</dragonfly>
