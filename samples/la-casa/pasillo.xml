<?xml version="1.0" encoding="UTF-8"?>

<!DOCTYPE dragonfly SYSTEM "../../templates/dragonfly.dtd">

<dragonfly>

	<noun names="El Pasillo, pasillo">

		<!-- Descripción del pasillo -->
		<after actions="LookAround">
			<response class="Message">
				A lo largo del pasillo, puedes ver unas puertas. Una hacia el norte y otra, mas alejada, hacia el este.
			</response>
		</after>

		<!-- La Puerta Este: (Pasillo a living).
			Ésta pueta es análoga a la que está en el living (oeste).
			En Dragonfly dos objetos no pueden compartir el mismo hijo, por eso
			se debe crear una puerta por cada lugar:
			- La puerta-living-pasillo ubicada en el living
			- La puerta-pasillo-living ubicada en el pasillo.

			Cuando se abre una, se abre la otra.
			Cuando se cierra una, se cierra la otra.
		-->
		<noun names="puerta este, puerta, este, puerta-pasillo-living">
			<set>female, fixed, closable, closed, scene, definited</set>

			<!-- Tiene la misma descripción que la del living
					(se supone que es la misma puerta para el jugador) -->	
			<after actions="ExamineObject">
				<response class="Message">
					La puerta este conduce a algún lugar de la casa.
				</response>
			</after>

			<!-- DESPUÉS de ABRIR PUERTA-->
			<after actions="OpenObject">
				<!-- Quitar atributo closed de la puerta del living -->
				<response class="Attr" unset="closed" instance="puerta-living-pasillo" />
			</after>

			<!-- DESPUÉS de cerrarla-->
			<after actions="CloseObject">
				<!-- Establecer el atributo closed de la puerta del living -->
				<response class="Attr" set="closed" instance="puerta-living-pasillo" />
			</after>
		</noun>

		<!-- Las otras puertas tienen el mismo funcionamiento -->
		<noun names="puerta norte, puerta, norte, puerta-pasillo-dormitorio">

			<set>female, fixed, closable, closed, scene, definited</set>

			<after actions="ExamineObject">
				<response class="Message">
					La puerta es de madera.
				</response>
			</after>

			<after actions="OpenObject">
				<response class="Attr" unset="closed" instance="puerta-dormitorio-pasillo" />
			</after>

			<after actions="CloseObject">
				<response class="Attr" set="closed" instance="puerta-dormitorio-pasillo" />
			</after>

		</noun>

		<!-- La puerta hacia el baño -->
		<noun names="puerta oeste, oeste, puerta, puerta-pasillo-toilette">
			<set>female, fixed, closable, closed, scene, definited, conllave</set>
			<!-- Se establece el atributo personalizado "conllave" para indicar
				mas adelante a la acción "abrir" que la puerta está con llave. -->
			<after actions="ExamineObject">
				<response class="Message">
					Es una puerta de madera.
				</response>
			</after>

			<!-- Antes de abrir, verifica si está con llave -->
			<before actions="OpenObject" cancel="true">
				<if class="IsSet" attr="conllave" instance="puerta-pasillo-toilette" />
				<response class="Message">
					La puerta está con llave.
				</response>
			</before>

			<!-- ANTES de abrir la puerta con el objeto directo,
				cancelar si ese objeto directo NO es la "llave" -->
			<before actions="OpenWith" cancel="true">
				<if class="IndirectNotEquals" instance="llave" />
				<response class="Message">
					No puedes abrir la puerta con eso.
				</response>
			</before>

			<before actions="OpenWith" cancel="true">
				<!-- Si está cerrada y la abro con la llave-->
				<if class="IndirectEquals" instance="llave" />
				<if class="IsSet" attr="closed" instance="puerta-pasillo-toilette" />
				<!-- Abro la puerta del pasillo y del baño -->
				<response class="Attr" unset="closed" instance="puerta-pasillo-toilette" />
				<response class="Attr" unset="closed" instance="puerta-toilette-pasillo" />
				<response class="Message">
					Abres la puerta.
				</response>

				<!-- Ahora se sabe que la llave es del baño, entonces se puede 
						agregar el nombre a la llave -->
				<!-- AppendName agrega un nombre a un objeto. Dicho nombre se
					volverá principal. Si el nombre ya existe, no agrega nada. -->
				<response class="AppendName" instance="llave" name="llave del baño"/>
				<!-- También queda bien que nos refiramos al objeto como "la llave del baño" y
						no como "una llave del baño" para eso se establece el atributo
						"definited" a la llave -->
				<response class="Attr" set="definited" instance="llave" />
			</before>
			
			<!-- Después de abrir o cerrar la puerta, abre o cierra "la del baño". -->
			<after actions="OpenObject, OpenWith">
				<response class="Attr" unset="closed" instance="puerta-toilette-pasillo" />
			</after>
			<after actions="CloseObject, CloseWith">
				<response class="Attr" set="closed" instance="puerta-toilette-pasillo" />
			</after>
		</noun>

		<!-- Conexiones -->
		<connection exit="este" destiny="living" />
		<connection exit="norte" destiny="dormitorio"/>
		<connection exit="oeste" destiny="toilette" />

		<!-- No deja pasar al jugador si la puerta-pasillo-living está cerrada -->
		<before actions="GoTo" cancel="true">
			<if class="DirectEqualsExit" exit="este" />
			<if class="IsSet" attr="closed" instance="puerta-pasillo-living" />
			<response class="Message">
				Primero debes abrir la puerta.
			</response>
		</before>
		<before actions="GoTo" cancel="true">
			<if class="DirectEqualsExit" exit="norte" />
			<if class="IsSet" attr="closed" instance="puerta-pasillo-dormitorio" />
			<response class="Message">
				Primero abre la puerta.
			</response>
		</before>
		<before actions="GoTo" cancel="true">
			<if class="DirectEqualsExit" exit="oeste" />
			<if class="IsSet" attr="closed" instance="puerta-pasillo-toilette" />
			<response class="Message">
				Primero abre la puerta.
			</response>
		</before>
	</noun>
</dragonfly>
