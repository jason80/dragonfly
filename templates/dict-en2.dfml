dictionary {

	verb(names: "?", action: "UnknownVerb") {
		response(id: "unknown-verb", string: "You don't know what you are saying.")
	}

	verb(names: "clear, cls, erase, clean, cleanse", action: "Clear")

	verb(names: "save", action: "SaveGame") {
		response(id: "game-saved", string: "Game saved.")
	}

	verb(names: "load, reload", action: "LoadObject", syntax: "1") {
		response(id: "direct-not-found", string: "That doesn't exist.")
		response(id: "direct-is-the-player", string: "You don't understand the idea.")
		response(id: "nothing-happens", string: "You cannot load this.")
	}

	verb(names: "load", action: "LoadGame") {
		response(id: "game-loaded", string: "Game loaded.")
	}

	verb(names: "inventory, i, inv", action: "Inventory") {
		response(id: "inventory-is-empty", string: "You have nothing in your possession.")
		response(id: "syntax-fail", string: "Type 'inventory' or 'i' to see what you are carrying.")
	}

	verb(names: "examine, look, see, find, seek, ex, x, l",
			action: "LookInside", syntax: "in/on/inner, 1") {
		response(id: "direct-not-found", string: "You can't find that.")
		response(id: "direct-is-the-player", string: "You can try: inventory or i.")
		response(id: "direct-is-not-container", string: "You can't see inside #1.")
		response(id: "direct-is-closed", string: "#^1 @1(is,is,are,are) closed.")
		response(id: "container-is-empty", string: "There is nothing in #1.")
	}

	verb(names: "examine, look, see, find, seek, ex, x, l",
			action: "ExamineObject", syntax: "to, 1") {
		response(id: "direct-not-found", string: "There is none of that.")
	}

	verb(names: "examine, look, see, find, seek, ex, x, l",
			action: "ExamineObject", syntax: "1") {
		response(id: "direct-not-found", string: "There is none of that.")
	}

	verb(names: "examine, look, see, find, seek, ex, x, l",
			action: "LookAround")

	verb(names: "examineme, lookme, im, iam",
			action: "ExamineMe")

	verb(names: "take, grab, pick, collect, get, obtain, seize, extract, gather, snatch",
		syntax: "1, from, 2", action: "TakeFrom") {
		response(id: "indirect-not-found", string: "You don't know where you want to take it from.")
		response(id: "indirect-is-not-container", string: "You can't take things from #2.")
		response(id: "indirect-is-closed", string: "#2 @2(is,is,are,are) closed.")
		response(id: "direct-not-found", string: "#^2 does not contain that.")
		response(id: "direct-taken", string: "You take #1 out of #2.")
		response(id: "syntax-fail", string: "You need to specify what you should take out.")
	}

	verb(names: "take, grab, pick, collect, get, obtain, seize",
		syntax: "1", action: "TakeObject") {
		response(id: "direct-not-found", string: "There is none of that.")
		response(id: "direct-is-the-player", string: "You can't take yourself.")
		response(id: "direct-is-fixed", string: "You can't take #1.")
		response(id: "direct-is-heavy", string: "#^1 @1(is,is,are,are) too heavy for you to carry @1(it,her,them,them).")
		response(id: "direct-taken", string: "You pick up #1.")
	}

	verb(names: "leave, let, release, drop, forget, place, put, set, insert, deposit, situate",
		syntax: "1, in/inside/within/into/internally, 2", action: "LeaveIn") {
		response(id: "indirect-not-found", string: "You can't leave it there.")
		response(id: "direct-not-found", string: "You don't have that.")
		response(id: "direct-is-the-player", string: "Put that in you?")
		response(id: "indirect-is-not-container", string: "You can't put #1 into #2.")
		response(id: "indirect-is-closed", string: "#^2 @2(is,is,are,are) closed.")
		response(id: "direct-leaved", string: "You leave #1 in #2.")
		response(id: "syntax-fail", string: "You need to say what you should leave.")
	}

	verb(names: "go, travel, walk", action: "GoTo",
