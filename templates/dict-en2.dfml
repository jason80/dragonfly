		response(id: "exit-not-exists", string: "You don't know that direction.")
		response(id: "exit-not-found", string: "You can't go that way.")
	}

	verb(names: "leave, release, drop, forget", action: "LeaveObject",
		syntax: "1") {
		response(id: "direct-not-found", string: "You don't have that.")
		response(id: "direct-left", string: "You leave #1.")
	}

	verb(names: "open", action: "OpenWith",
